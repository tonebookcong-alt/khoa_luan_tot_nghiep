# ==================== PostgreSQL ====================
POSTGRES_USER=phonemarket
POSTGRES_PASSWORD=phonemarket123
POSTGRES_DB=phonemarket
DATABASE_URL="postgresql://phonemarket:phonemarket123@localhost:5432/phonemarket"

# ==================== MongoDB ====================
MONGO_USER=phonemarket
MONGO_PASSWORD=phonemarket123
MONGO_DB=phonemarket_ai
MONGODB_URI="mongodb://phonemarket:phonemarket123@localhost:27017/phonemarket_ai?authSource=admin"

# ==================== Redis ====================
REDIS_PASSWORD=phonemarket123
REDIS_URL="redis://:phonemarket123@localhost:6379"

# ==================== Backend (NestJS) ====================
PORT=3001
NODE_ENV=development

JWT_ACCESS_SECRET=your_access_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# VNPAY
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_SECURE_HASH_KEY=your_vnpay_secure_hash_key
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payment/return

# File upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB

# ==================== AI Service ====================
AI_SERVICE_PORT=3002
AI_SERVICE_URL=http://localhost:3002

# Gemini
GEMINI_API_KEY=your_gemini_api_key

# ==================== Frontend (Next.js) ====================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:3002
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
